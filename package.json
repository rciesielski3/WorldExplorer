{
  "name": "worldexplorer",
  "license": "0BSD",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "countries:generate": "tsx scripts/countries/generate.ts",
    "countries:update": "tsx scripts/countries/update.ts",
    "countries:validate": "tsx scripts/countries/validate.ts",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/exo-2": "^0.2.3",
    "@expo/config-plugins": "~10.1.1",
    "@expo/prebuild-config": "~9.0.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/stack": "^7.1.1",
    "axios": "^1.7.9",
    "dotenv": "^16.5.0",
    "expo": "^53.0.0",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-modules-core": "~2.5.0",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~0.28.18",
    "i18next": "^24.2.2",
    "lottie-react-native": "7.2.2",
    "react": "19.0.0",
    "react-i18next": "^15.4.0",
    "react-native": "0.79.6",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-google-mobile-ads": "^15.7.0",
    "react-native-maps": "1.20.1",
    "react-native-paper": "^5.13.1",
    "react-native-purchases": "^10.2.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-toast-message": "^2.2.1",
    "react-native-vector-icons": "^10.2.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/gradle-plugin": "0.79.6",
    "@types/react": "~19.0.10",
    "patch-package": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-maps"
        ]
      },
      "android": {
        "permissions": [
          "ACCESS_FINE_LOCATION",
          "ACCESS_COARSE_LOCATION"
        ]
      }
    }
  }
}
