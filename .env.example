# Google Maps API Key (required for Maps feature)
# Generate at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration (required for backend services)
# Generate at: https://console.firebase.google.com/
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here

# Firebase Client SDK (used by firebase-config.ts for Firestore-backed
# features such as historical facts and favorites sync)
# Generate at: Firebase Console -> Project Settings -> Web App Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# For local Firebase Emulator (optional, for development)
FIREBASE_EMULATOR_HOST=localhost:8080

# Firebase Admin SDK (used only by scripts/firebase/seed-facts.ts, never
# bundled into the app). Path to a service account JSON file - keep this
# file out of version control.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# AdMob Configuration (required for ads)
# Generate at: https://admob.google.com/
ADMOB_APP_ID=your_admob_app_id_here
ADMOB_BANNER_ID=your_admob_banner_id_here
ADMOB_INTERSTITIAL_ID=your_admob_interstitial_id_here

# Premium Features (RevenueCat)
# Generate at: https://www.revenuecat.com/
EXPO_PUBLIC_PREMIUM_ENABLED=true
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your_revenuecat_android_key_here
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your_revenuecat_ios_key_here
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
EXPO_PUBLIC_REVENUECAT_PREMIUM_PRODUCT_ID=worldexplorer_premium_lifetime

# Environment
NODE_ENV=production
